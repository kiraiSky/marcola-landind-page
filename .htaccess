# ============================================================
# Marcola Garagem — Apache server config
# Security headers + HTTPS/WWW redirects
# ============================================================

# --- Force HTTPS ---
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Force www (canonical: www.marcolagaragem.com) ---
RewriteCond %{HTTP_HOST} ^marcolagaragem\.com$ [NC]
RewriteRule ^ https://www.marcolagaragem.com%{REQUEST_URI} [L,R=301]

# --- Security headers ---
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.google.com; connect-src 'self' https://kiraiskyn8n.duckdns.org; upgrade-insecure-requests"
</IfModule>

# --- Cache control (evita JS/CSS stale após deploy) ---
<IfModule mod_headers.c>
  # HTML: nunca cachear (re-revalida sempre, apanha novos hashes de assets)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Assets versionados: cache longo (filename muda quando ?v= muda)
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# --- Default doc ---
DirectoryIndex index.html
